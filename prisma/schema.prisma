generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// CORE — Users, Auth, Notifications
// ============================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  name            String?
  username        String?   @unique
  image           String?
  passwordHash    String?
  avatarUrl       String?
  bio             String?
  karma           Int       @default(0)
  creditSeed      Int       @default(500)
  creditPurchased Int       @default(0)
  creditEarned    Int       @default(0)
  role            UserRole  @default(user)
  bannedAt              DateTime?
  onboardingStep        Int       @default(1)
  onboardingCompletedAt DateTime?
  location        String?
  ridingStyle     String?
  interests       String[]    @default([])
  skillLevel      SkillLevel?
  favoriteBike    String?
  favoriteTrail   String?
  yearsRiding     Int?
  websiteUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  emailNotifications Boolean @default(true)
  lastActivityAt  DateTime?
  accounts        Account[]
  sessions        Session[]
  xpGrants        XpGrant[]
  xpAggregate     XpAggregate?
  forumPosts              ForumPost[]
  forumVotes              ForumVote[]
  forumBookmarks          ForumBookmark[]
  ownedForumCommunities   ForumCategory[]              @relation("ownedForumCommunities")
  forumMemberships        ForumCommunityMembership[]
  forumReports            ForumReport[]                @relation("forumReporter")
  forumModActions         ForumReport[]                @relation("forumModerator")
  forumBadges             ForumUserBadge[]
  conversations           ConversationParticipant[]
  sentMessages            DirectMessage[]
  creditTransactions      CreditTransaction[]
  tipsSent                CreditTip[]              @relation("TipsSent")
  tipsReceived            CreditTip[]              @relation("TipsReceived")
  learnAttempts      LearnQuizAttempt[]
  learnProgress      LearnProgress[]
  learnCerts         LearnCertificate[]
  learnChatMessages  LearnChatMessage[]
  trailReviews      TrailReview[]
  trailFavorites    TrailFavorite[]
  rideLogs          RideLog[]
  conditionReports  ConditionReport[]
  notifications   Notification[]
  events          Event[]
  eventRsvps      EventRsvp[]
  eventComments   EventComment[]
  organizerProfile OrganizerProfile?
  gearReviews     GearReview[]
  userBikes       UserBike[]
  buildLogEntries BuildLogEntry[]
  mediaItems      MediaItem[]
  listings         Listing[]
  listingFavorites ListingFavorite[]
  sellerProfile    SellerProfile?
  offers           Offer[]                 @relation("OfferBuyer")
  buyerConversations   ListingConversation[] @relation("ConvBuyer")
  sellerConversations  ListingConversation[] @relation("ConvSeller")
  listingMessages  ListingMessage[]        @relation("ListingMsgSender")
  sellerReviews    SellerReview[]          @relation("SellerReviewer")
  buyerTransactions    Transaction[]       @relation("TxBuyer")
  sellerTransactions   Transaction[]       @relation("TxSeller")
  listingSaves     ListingSave[]
  listingReports   ListingReport[]
  listingPayments  ListingPayment[]        @relation("ListingPayments")
  shops           Shop[]
  shopReviews     ShopReview[]
  reviewHelpfulVotes ReviewHelpful[]
  coachProfile    CoachProfile?
  creatorProfile  CreatorProfile?
  quizSessions          QuizSession[]
  quizResults           QuizResult[]
  bikeConsultations     BikeConsultationRequest[]
  cartItems             CartItem[]
  wishlistItems         WishlistItem[]
  dropSubscription      DropSubscriber?
  articles   Article[]  @relation("ArticleAuthor")
  coachApplications    CoachApplication[] @relation("CoachApplications")
  reviewedApplications CoachApplication[] @relation("CoachApplicationReviewer")
  affiliateClicks  AffiliateClick[] @relation("AffiliateClicks")
  fantasyTeams             FantasyTeam[]
  fantasyLeaguesCreated    FantasyLeague[]           @relation("LeagueCreator")
  fantasyLeagueMemberships FantasyLeagueMember[]
  seasonPasses             SeasonPassPurchase[]
  mulliganBalance          MulliganBalance?
  mulliganPurchases        MulliganPurchase[]
  mulliganUses             MulliganUse[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  linkUrl   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// ============================================================
// XP ENGINE
// ============================================================

model XpGrant {
  id         String   @id @default(cuid())
  userId     String
  event      XpEvent
  module     XpModule
  points     Int
  multiplier Float    @default(1.0)
  total      Int
  refId      String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, event, refId])
  @@index([userId, module])
  @@index([userId, createdAt])
  @@map("xp_grants")
}

model XpAggregate {
  id             String   @id @default(cuid())
  userId         String   @unique
  totalXp        Int      @default(0)
  moduleBreakdown Json    @default("{}")
  streakDays     Int      @default(0)
  lastGrantAt    DateTime?
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("xp_aggregates")
}

// ============================================================
// FORUM
// ============================================================

model ForumCategory {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  description   String?
  icon          String?
  color         String      @default("#6b7280")
  sortOrder     Int         @default(0)
  // Community fields
  isGated       Boolean     @default(false)
  ownerId       String?
  coverImageUrl String?
  memberCount   Int         @default(0)
  owner         User?       @relation("ownedForumCommunities", fields: [ownerId], references: [id])
  threads       ForumThread[]
  memberships   ForumCommunityMembership[]

  @@map("forum_categories")
}

model ForumCommunityMembership {
  id         String        @id @default(cuid())
  userId     String
  categoryId String
  role       String        @default("member")
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@map("forum_community_memberships")
}

model ForumThread {
  id          String        @id @default(cuid())
  categoryId  String
  title       String
  slug        String        @unique
  isPinned    Boolean       @default(false)
  isLocked    Boolean       @default(false)
  viewCount   Int           @default(0)
  hotScore    Float         @default(0)
  lastReplyAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  category    ForumCategory @relation(fields: [categoryId], references: [id])
  posts       ForumPost[]
  tags        ForumThreadTag[]
  bookmarks   ForumBookmark[]
  reports     ForumReport[]

  @@index([categoryId, createdAt])
  @@index([hotScore])
  @@index([deletedAt])
  @@map("forum_threads")
}

model ForumPost {
  id        String      @id @default(cuid())
  threadId  String
  authorId  String
  content   String      @db.Text
  isFirst   Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  editedAt  DateTime?
  deletedAt DateTime?
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes     ForumVote[]
  reports   ForumReport[]

  @@index([threadId, createdAt])
  @@index([authorId])
  @@map("forum_posts")
}

model ForumVote {
  id     String @id @default(cuid())
  postId String
  userId String
  value  Int
  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("forum_votes")
}

model ForumTag {
  id      String          @id @default(cuid())
  name    String          @unique
  slug    String          @unique
  color   String          @default("#6b7280")
  threads ForumThreadTag[]

  @@map("forum_tags")
}

model ForumThreadTag {
  threadId String
  tagId    String
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  tag      ForumTag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([threadId, tagId])
  @@map("forum_thread_tags")
}

model ForumBookmark {
  id        String      @id @default(cuid())
  userId    String
  threadId  String
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@map("forum_bookmarks")
}

model ForumReport {
  id           String              @id @default(cuid())
  reporterId   String
  targetType   ForumReportTarget
  postId       String?
  threadId     String?
  reportedUserId String?
  reason       String
  status       ForumReportStatus   @default(OPEN)
  moderatorId  String?
  modNote      String?
  resolvedAt   DateTime?
  createdAt    DateTime            @default(now())

  reporter     User        @relation("forumReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  moderator    User?       @relation("forumModerator", fields: [moderatorId], references: [id], onDelete: SetNull)
  post         ForumPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  thread       ForumThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("forum_reports")
}

model ForumBadge {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  description String
  icon        String
  color       String
  createdAt   DateTime         @default(now())
  userBadges  ForumUserBadge[]

  @@map("forum_badges")
}

model ForumUserBadge {
  id        String     @id @default(cuid())
  userId    String
  badgeSlug String
  awardedAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     ForumBadge @relation(fields: [badgeSlug], references: [slug])

  @@unique([userId, badgeSlug])
  @@map("forum_user_badges")
}

// ============================================================
// LEARN
// ============================================================

model LearnCourse {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  description  String?       @db.Text
  thumbnailUrl String?
  difficulty   Difficulty    @default(beginner)
  category     LearnCategory @default(riding_skills)
  sortOrder    Int           @default(0)
  status       ContentStatus @default(draft)
  sponsorId    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  modules      LearnModule[]
  certificates LearnCertificate[]

  @@map("learn_courses")
}

model LearnModule {
  id             String       @id @default(cuid())
  courseId        String
  slug            String
  title           String
  sortOrder       Int          @default(0)
  lessonContent   Json?
  youtubeVideoId  String?
  status          ContentStatus @default(draft)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  course          LearnCourse  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quiz            LearnQuiz?

  @@unique([courseId, slug])
  @@map("learn_modules")
}

model LearnQuiz {
  id          String             @id @default(cuid())
  moduleId    String?            @unique
  slug        String             @unique
  title       String
  description String?
  difficulty  Difficulty         @default(beginner)
  category    LearnCategory      @default(riding_skills)
  status      ContentStatus      @default(draft)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  module      LearnModule?       @relation(fields: [moduleId], references: [id])
  questions   LearnQuestion[]
  attempts    LearnQuizAttempt[]
  progress    LearnProgress[]

  @@map("learn_quizzes")
}

model LearnQuestion {
  id                String       @id @default(cuid())
  quizId            String
  sortOrder         Int          @default(0)
  type              QuestionType
  prompt            String
  promptImageUrl    String?
  options           Json
  explanation       String?      @db.Text
  interactiveConfig Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  quiz              LearnQuiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, sortOrder])
  @@map("learn_questions")
}

model LearnQuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Float
  tier        Tier
  xpEarned    Int      @default(0)
  answers     Json
  completedAt DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz        LearnQuiz @relation(fields: [quizId], references: [id])

  @@index([userId, quizId])
  @@map("learn_quiz_attempts")
}

model LearnProgress {
  id       String @id @default(cuid())
  userId   String
  quizId   String
  bestTier Tier
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz     LearnQuiz @relation(fields: [quizId], references: [id])

  @@unique([userId, quizId])
  @@map("learn_progress")
}

model LearnCertificate {
  id        String      @id @default(cuid())
  userId    String
  courseId   String
  tier       Tier
  issuedAt   DateTime   @default(now())
  pdfUrl     String?
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     LearnCourse @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@map("learn_certificates")
}

model LearnChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" | "assistant"
  content   String   @db.Text
  courseId  String?  // optional context
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("learn_chat_messages")
}

// ============================================================
// TRAILS
// ============================================================

model TrailSystem {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  description   String?          @db.Text
  city          String?
  state         String?
  country       String           @default("US")
  latitude      Float?
  longitude     Float?
  websiteUrl    String?
  systemType    TrailSystemType  @default(trail_network)
  status        TrailStatus      @default(open)
  totalMiles    Float            @default(0)
  trailCount    Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  regionId      String?
  trails        Trail[]
  region        TrailRegion? @relation(fields: [regionId], references: [id])
  pois          PointOfInterest[]
  rideLogs      RideLog[]
  creatorVideos   CreatorVideo[]

  @@index([city, state])
  @@index([latitude, longitude])
  @@map("trail_systems")
}

model Trail {
  id                String        @id @default(cuid())
  trailSystemId     String
  name              String
  slug              String        @unique
  description       String?       @db.Text
  trailType         TrailType     @default(xc)
  physicalDifficulty Int          @default(1)
  technicalDifficulty Int         @default(1)
  distance          Float?
  elevationGain     Float?
  elevationLoss     Float?
  highPoint         Float?
  lowPoint          Float?
  status            TrailStatus   @default(open)
  condition         TrailCondition?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  currentCondition      ConditionType?
  conditionReportedAt   DateTime?
  system            TrailSystem   @relation(fields: [trailSystemId], references: [id])
  gpsTrack          TrailGpsTrack?
  reviews           TrailReview[]
  favorites         TrailFavorite[]
  conditionReports  ConditionReport[]
  pois              PointOfInterest[]
  rideLogs          RideLog[]

  @@index([trailSystemId, status])
  @@index([trailType])
  @@map("trails")
}

model TrailGpsTrack {
  id               String   @id @default(cuid())
  trailId          String   @unique
  gpxFileUrl       String?
  boundsNeLat      Float?
  boundsNeLng      Float?
  boundsSwLat      Float?
  boundsSwLng      Float?
  pointCount       Int      @default(0)
  simplifiedTrack  String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  trail            Trail    @relation(fields: [trailId], references: [id], onDelete: Cascade)

  @@map("trail_gps_tracks")
}

model TrailReview {
  id              String   @id @default(cuid())
  trailId         String
  userId          String
  rating          Int
  flowRating      Int?
  sceneryRating   Int?
  technicalRating Int?
  maintenanceRating Int?
  comment         String?  @db.Text
  rideDate        DateTime?
  bikeType        String?
  createdAt       DateTime @default(now())
  trail           Trail    @relation(fields: [trailId], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([trailId, userId])
  @@index([trailId, createdAt])
  @@map("trail_reviews")
}

model TrailFavorite {
  id        String   @id @default(cuid())
  trailId   String
  userId    String
  createdAt DateTime @default(now())
  trail     Trail    @relation(fields: [trailId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([trailId, userId])
  @@map("trail_favorites")
}

model RideLog {
  id              String    @id @default(cuid())
  userId          String
  trailId         String?
  trailSystemId   String?
  date            DateTime
  duration        Int?
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trail           Trail?       @relation(fields: [trailId], references: [id])
  trailSystem     TrailSystem? @relation(fields: [trailSystemId], references: [id])

  @@index([userId, date])
  @@map("ride_logs")
}

model ConditionReport {
  id          String        @id @default(cuid())
  trailId     String
  userId      String
  condition   ConditionType
  notes       String?       @db.VarChar(500)
  reportedAt  DateTime      @default(now())
  trail       Trail         @relation(fields: [trailId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trailId, reportedAt])
  @@map("condition_reports")
}

model PointOfInterest {
  id              String   @id @default(cuid())
  trailId         String?
  trailSystemId   String?
  type            PoiType
  name            String
  description     String?
  lat             Float
  lng             Float
  distanceAlongMi Float?
  createdAt       DateTime @default(now())
  trail           Trail?       @relation(fields: [trailId], references: [id], onDelete: Cascade)
  trailSystem     TrailSystem? @relation(fields: [trailSystemId], references: [id], onDelete: Cascade)

  @@map("points_of_interest")
}

model TrailRegion {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  state       String?
  country     String        @default("US")
  lat         Float?
  lng         Float?
  systems     TrailSystem[]
  createdAt   DateTime      @default(now())

  @@map("trail_regions")
}

// ============================================================
// EVENTS
// ============================================================

model Event {
  id          String      @id @default(cuid())
  creatorId   String
  title       String
  slug        String      @unique
  description String?     @db.Text
  location    String
  latitude    Float?
  longitude   Float?
  startDate   DateTime
  endDate     DateTime?
  maxAttendees Int?
  imageUrl    String?
  eventType   EventType   @default(group_ride)
  status      ContentStatus @default(published)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  // New fields from race calendar port
  eventTypeEnum         EventTypeEnum?
  organizerId           String?
  organizer             OrganizerProfile? @relation(fields: [organizerId], references: [id])
  registrationUrl       String?
  registrationDeadline  DateTime?
  costCents             Int?
  isFree                Boolean  @default(false)
  isFeatured            Boolean  @default(false)
  resultsUrl            String?
  resultsPosted         Boolean  @default(false)
  creator     User        @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  rsvps       EventRsvp[]
  comments    EventComment[]

  @@index([startDate])
  @@index([creatorId])
  @@map("events")
}

model EventComment {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  parentId  String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    EventComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   EventComment[] @relation("CommentReplies")

  @@index([eventId, createdAt])
  @@map("event_comments")
}

model OrganizerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  orgName     String
  bio         String?
  websiteUrl  String?
  logoUrl     String?
  isVerified  Boolean  @default(false)
  eventCount  Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  events      Event[]

  @@map("organizer_profiles")
}

model EventRsvp {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  status    RsvpStatus @default(going)
  createdAt DateTime   @default(now())
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_rsvps")
}

// ============================================================
// GEAR REVIEWS
// ============================================================

model GearReview {
  id           String   @id @default(cuid())
  userId       String
  title        String
  slug         String   @unique
  category     GearCategory
  brand        String
  productName  String
  rating       Int
  pros         String?  @db.Text
  cons         String?  @db.Text
  content      String   @db.Text
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([userId])
  @@index([rating])
  @@map("gear_reviews")
}

// ============================================================
// BIKE GARAGE
// ============================================================

model UserBike {
  id           String           @id @default(cuid())
  userId       String
  name         String
  brand        String
  model        String
  year         Int?
  category     BikeCategory
  wheelSize    String?
  frameSize    String?
  weight       Float?
  imageUrl     String?
  isPrimary    Boolean          @default(false)
  notes        String?          @db.Text
  frameMaterial String?
  travel        Int?
  purchaseYear  Int?
  purchasePrice Int?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
