generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// CORE — Users, Auth, Notifications
// ============================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerified   DateTime?
  name            String?
  username        String?   @unique
  image           String?
  passwordHash    String?
  avatarUrl       String?
  bio             String?
  role            UserRole  @default(user)
  bannedAt        DateTime?
  location        String?
  ridingStyle     String?
  skillLevel      SkillLevel?
  favoriteBike    String?
  favoriteTrail   String?
  yearsRiding     Int?
  websiteUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastActivityAt  DateTime?
  accounts        Account[]
  sessions        Session[]
  xpGrants        XpGrant[]
  xpAggregate     XpAggregate?
  forumPosts      ForumPost[]
  forumVotes      ForumVote[]
  learnAttempts   LearnQuizAttempt[]
  learnProgress   LearnProgress[]
  learnCerts      LearnCertificate[]
  trailReviews    TrailReview[]
  trailFavorites  TrailFavorite[]
  rideLogs        RideLog[]
  notifications   Notification[]
  events          Event[]
  eventRsvps      EventRsvp[]
  gearReviews     GearReview[]
  userBikes       UserBike[]
  mediaItems      MediaItem[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  linkUrl   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// ============================================================
// XP ENGINE
// ============================================================

model XpGrant {
  id         String   @id @default(cuid())
  userId     String
  event      XpEvent
  module     XpModule
  points     Int
  multiplier Float    @default(1.0)
  total      Int
  refId      String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, event, refId])
  @@index([userId, module])
  @@index([userId, createdAt])
  @@map("xp_grants")
}

model XpAggregate {
  id             String   @id @default(cuid())
  userId         String   @unique
  totalXp        Int      @default(0)
  moduleBreakdown Json    @default("{}")
  streakDays     Int      @default(0)
  lastGrantAt    DateTime?
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("xp_aggregates")
}

// ============================================================
// FORUM
// ============================================================

model ForumCategory {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  icon        String?
  sortOrder   Int         @default(0)
  threads     ForumThread[]

  @@map("forum_categories")
}

model ForumThread {
  id          String        @id @default(cuid())
  categoryId  String
  title       String
  slug        String        @unique
  isPinned    Boolean       @default(false)
  isLocked    Boolean       @default(false)
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  category    ForumCategory @relation(fields: [categoryId], references: [id])
  posts       ForumPost[]

  @@index([categoryId, createdAt])
  @@map("forum_threads")
}

model ForumPost {
  id        String      @id @default(cuid())
  threadId  String
  authorId  String
  content   String      @db.Text
  isFirst   Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User        @relation(fields: [authorId], references: [id])
  votes     ForumVote[]

  @@index([threadId, createdAt])
  @@index([authorId])
  @@map("forum_posts")
}

model ForumVote {
  id     String @id @default(cuid())
  postId String
  userId String
  value  Int
  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User      @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@map("forum_votes")
}

// ============================================================
// LEARN
// ============================================================

model LearnCourse {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  description  String?       @db.Text
  thumbnailUrl String?
  difficulty   Difficulty    @default(beginner)
  category     LearnCategory @default(riding_skills)
  sortOrder    Int           @default(0)
  status       ContentStatus @default(draft)
  sponsorId    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  modules      LearnModule[]
  certificates LearnCertificate[]

  @@map("learn_courses")
}

model LearnModule {
  id             String       @id @default(cuid())
  courseId        String
  slug            String
  title           String
  sortOrder       Int          @default(0)
  lessonContent   Json?
  youtubeVideoId  String?
  status          ContentStatus @default(draft)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  course          LearnCourse  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quiz            LearnQuiz?

  @@unique([courseId, slug])
  @@map("learn_modules")
}

model LearnQuiz {
  id          String             @id @default(cuid())
  moduleId    String?            @unique
  slug        String             @unique
  title       String
  description String?
  difficulty  Difficulty         @default(beginner)
  category    LearnCategory      @default(riding_skills)
  status      ContentStatus      @default(draft)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  module      LearnModule?       @relation(fields: [moduleId], references: [id])
  questions   LearnQuestion[]
  attempts    LearnQuizAttempt[]
  progress    LearnProgress[]

  @@map("learn_quizzes")
}

model LearnQuestion {
  id                String       @id @default(cuid())
  quizId            String
  sortOrder         Int          @default(0)
  type              QuestionType
  prompt            String
  promptImageUrl    String?
  options           Json
  explanation       String?      @db.Text
  interactiveConfig Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  quiz              LearnQuiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, sortOrder])
  @@map("learn_questions")
}

model LearnQuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Float
  tier        Tier
  xpEarned    Int      @default(0)
  answers     Json
  completedAt DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  quiz        LearnQuiz @relation(fields: [quizId], references: [id])

  @@index([userId, quizId])
  @@map("learn_quiz_attempts")
}

model LearnProgress {
  id       String @id @default(cuid())
  userId   String
  quizId   String
  bestTier Tier
  user     User   @relation(fields: [userId], references: [id])
  quiz     LearnQuiz @relation(fields: [quizId], references: [id])

  @@unique([userId, quizId])
  @@map("learn_progress")
}

model LearnCertificate {
  id        String      @id @default(cuid())
  userId    String
  courseId   String
  tier       Tier
  issuedAt   DateTime   @default(now())
  pdfUrl     String?
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     LearnCourse @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@map("learn_certificates")
}

// ============================================================
// TRAILS
// ============================================================

model TrailSystem {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  description   String?          @db.Text
  city          String?
  state         String?
  country       String           @default("US")
  latitude      Float?
  longitude     Float?
  websiteUrl    String?
  systemType    TrailSystemType  @default(trail_network)
  status        TrailStatus      @default(open)
  totalMiles    Float            @default(0)
  trailCount    Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  trails        Trail[]

  @@index([city, state])
  @@index([latitude, longitude])
  @@map("trail_systems")
}

model Trail {
  id                String        @id @default(cuid())
  trailSystemId     String
  name              String
  slug              String        @unique
  description       String?       @db.Text
  trailType         TrailType     @default(xc)
  physicalDifficulty Int          @default(1)
  technicalDifficulty Int         @default(1)
  distance          Float?
  elevationGain     Float?
  elevationLoss     Float?
  highPoint         Float?
  lowPoint          Float?
  status            TrailStatus   @default(open)
  condition         TrailCondition?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  system            TrailSystem   @relation(fields: [trailSystemId], references: [id])
  gpsTrack          TrailGpsTrack?
  reviews           TrailReview[]
  favorites         TrailFavorite[]

  @@index([trailSystemId, status])
  @@index([trailType])
  @@map("trails")
}

model TrailGpsTrack {
  id               String   @id @default(cuid())
  trailId          String   @unique
  gpxFileUrl       String?
  boundsNeLat      Float?
  boundsNeLng      Float?
  boundsSwLat      Float?
  boundsSwLng      Float?
  pointCount       Int      @default(0)
  simplifiedTrack  String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  trail            Trail    @relation(fields: [trailId], references: [id], onDelete: Cascade)

  @@map("trail_gps_tracks")
}

model TrailReview {
  id              String   @id @default(cuid())
  trailId         String
  userId          String
  rating          Int
  flowRating      Int?
  sceneryRating   Int?
  technicalRating Int?
  maintenanceRating Int?
  comment         String?  @db.Text
  rideDate        DateTime?
  bikeType        String?
  createdAt       DateTime @default(now())
  trail           Trail    @relation(fields: [trailId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@unique([trailId, userId])
  @@index([trailId, createdAt])
  @@map("trail_reviews")
}

model TrailFavorite {
  id        String   @id @default(cuid())
  trailId   String
  userId    String
  createdAt DateTime @default(now())
  trail     Trail    @relation(fields: [trailId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([trailId, userId])
  @@map("trail_favorites")
}

model RideLog {
  id        String    @id @default(cuid())
  userId    String
  trailId   String?
  date      DateTime
  duration  Int?
  notes     String?   @db.Text
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@map("ride_logs")
}

// ============================================================
// EVENTS
// ============================================================

model Event {
  id          String      @id @default(cuid())
  creatorId   String
  title       String
  slug        String      @unique
  description String?     @db.Text
  location    String
  latitude    Float?
  longitude   Float?
  startDate   DateTime
  endDate     DateTime?
  maxAttendees Int?
  imageUrl    String?
  eventType   EventType   @default(group_ride)
  status      ContentStatus @default(published)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  creator     User        @relation(fields: [creatorId], references: [id])
  rsvps       EventRsvp[]

  @@index([startDate])
  @@index([creatorId])
  @@map("events")
}

model EventRsvp {
  id        String     @id @default(cuid())
  eventId   String
  userId    String
  status    RsvpStatus @default(going)
  createdAt DateTime   @default(now())
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("event_rsvps")
}

// ============================================================
// GEAR REVIEWS
// ============================================================

model GearReview {
  id           String   @id @default(cuid())
  userId       String
  title        String
  slug         String   @unique
  category     GearCategory
  brand        String
  productName  String
  rating       Int
  pros         String?  @db.Text
  cons         String?  @db.Text
  content      String   @db.Text
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@index([category])
  @@index([userId])
  @@index([rating])
  @@map("gear_reviews")
}

// ============================================================
// BIKE GARAGE
// ============================================================

model UserBike {
  id           String           @id @default(cuid())
  userId       String
  name         String
  brand        String
  model        String
  year         Int?
  category     BikeCategory
  wheelSize    String?
  frameSize    String?
  weight       Float?
  imageUrl     String?
  isPrimary    Boolean          @default(false)
  notes        String?          @db.Text
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceLogs  BikeServiceLog[]

  @@index([userId])
  @@map("user_bikes")
}

model BikeServiceLog {
  id          String   @id @default(cuid())
  bikeId      String
  serviceType String
  description String?  @db.Text
  cost        Float?
  serviceDate DateTime
  mileage     Float?
  createdAt   DateTime @default(now())
  bike        UserBike @relation(fields: [bikeId], references: [id], onDelete: Cascade)

  @@index([bikeId, serviceDate])
  @@map("bike_service_logs")
}

// ============================================================
// MEDIA
// ============================================================

model MediaItem {
  id          String    @id @default(cuid())
  userId      String
  mediaType   MediaType
  url         String
  thumbnailUrl String?
  title       String?
  description String?
  trailId     String?
  rideLogId   String?
  width       Int?
  height      Int?
  fileSize    Int?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([trailId])
  @@map("media_items")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  user
  instructor
  admin
}

enum SkillLevel {
  beginner
  intermediate
  advanced
  expert
}

enum Difficulty {
  beginner
  intermediate
  advanced
}

enum ContentStatus {
  draft
  published
  archived
}

enum Tier {
  gold
  silver
  bronze
  incomplete
}

enum QuestionType {
  multiple_choice
  true_false
  image_based
  drag_drop
  diagram_match
  hotspot
}

enum LearnCategory {
  riding_skills
  maintenance
  fitness
  etiquette
  nutrition
  gear
}

enum XpModule {
  forum
  learn
  trails
  bikes
  events
  reviews
  rides
  marketplace
  merch
  shops
  media
  coaching
}

enum XpEvent {
  forum_post_created
  forum_thread_created
  forum_vote_received
  learn_quiz_completed
  learn_quiz_improved
  learn_module_completed
  learn_course_completed
  trail_review_submitted
  trail_condition_reported
  trail_photo_uploaded
  trail_gpx_contributed
  ride_logged
  review_submitted
  event_attended
  streak_bonus
}

enum TrailSystemType {
  bike_park
  trail_network
  open_space
  private_property
  urban_park
  skills_park
  other
}

enum TrailType {
  xc
  downhill
  enduro
  flow
  freeride
  climbing
  connector
  out_and_back
  loop
  shuttle
  pump_track
  skills_area
  other
}

enum TrailStatus {
  pending
  open
  closed_seasonal
  closed_conditions
  closed_construction
  closed_permanent
  unknown
}

enum TrailCondition {
  dry_fast
  dry_dusty
  tacky_perfect
  damp
  muddy
  snow_ice
  flooded
  fallen_trees
  construction
}

enum EventType {
  group_ride
  race
  skills_clinic
  trail_work
  social
  demo_day
  other
}

enum RsvpStatus {
  going
  maybe
  not_going
}

enum GearCategory {
  bikes
  helmets
  protection
  shoes
  clothing
  wheels
  suspension
  drivetrain
  brakes
  cockpit
  accessories
  tools
  other
}

enum BikeCategory {
  gravel
  xc
  trail
  enduro
  downhill
  dirt_jump
  ebike
  other
}

enum MediaType {
  photo
  video
}
