# ─────────────────────────────────────────────
# Database  (Supabase session pooler — aws-1-)
# ─────────────────────────────────────────────
DATABASE_DIRECT_URL=postgresql://postgres.your-project:your-password@aws-1-us-west-1.pooler.supabase.com:5432/postgres
DATABASE_POOLED_URL=postgresql://postgres.your-project:your-password@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
AUTH_SECRET=your-secret-at-least-32-characters-long
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─────────────────────────────────────────────
# Supabase (client-side storage/realtime)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─────────────────────────────────────────────
# App URL
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# AI
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─────────────────────────────────────────────
# Maps
# ─────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token
MAPBOX_ACCESS_TOKEN=sk.your-mapbox-secret-token

# ─────────────────────────────────────────────
# Cron security
# ─────────────────────────────────────────────
CRON_SECRET=your-cron-secret-min-16-chars

# ─────────────────────────────────────────────
# Upstash Redis (rate limiting + feed scoring)
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─────────────────────────────────────────────
# Email (SendGrid) — optional; disables email notifications if absent
# ─────────────────────────────────────────────
# SENDGRID_API_KEY=SG.your-sendgrid-api-key

# ─────────────────────────────────────────────
# Stripe — optional; required for paid features
# ─────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
# STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
# PLATFORM_FEE_PERCENT=5
# FANTASY_STRIPE_WEBHOOK_SECRET=whsec_your-fantasy-stripe-webhook-secret
# STRIPE_SEASON_PASS_PRICE_ID=price_your-season-pass-price-id
# STRIPE_MULLIGAN_1_PRICE_ID=price_your-mulligan-1-price-id
# STRIPE_MULLIGAN_3_PRICE_ID=price_your-mulligan-3-price-id

# ─────────────────────────────────────────────
# YouTube — optional; required for creator RSS ingestion
# ─────────────────────────────────────────────
# YOUTUBE_API_KEY=AIza-your-youtube-api-key

# ─────────────────────────────────────────────
# Twitter/X — optional; required for X embed features
# ─────────────────────────────────────────────
# TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ─────────────────────────────────────────────
# Fantasy — optional; enables bot forum posts on roster lock
# ─────────────────────────────────────────────
# FANTASY_BOT_USER_ID=your-fantasy-bot-user-uuid

# ─────────────────────────────────────────────
# Bunny CDN — optional; video delivery
# ─────────────────────────────────────────────
# BUNNY_CDN_HOSTNAME=your-pullzone.b-cdn.net
# NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=your-pullzone.b-cdn.net

# ─────────────────────────────────────────────
# Analytics — optional
# ─────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key

# ─────────────────────────────────────────────
# Scheduling — optional
# ─────────────────────────────────────────────
# NEXT_PUBLIC_CALCOM_LINK=https://cal.com/your-handle/consultation

# ─────────────────────────────────────────────
# Feature flags
# ─────────────────────────────────────────────
FEATURE_COACHING=false
FEATURE_MARKETPLACE=false
FEATURE_MERCH=false
