# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/ridemtb
DATABASE_POOLED_URL=postgresql://user:pass@localhost:6543/ridemtb?pgbouncer=true

# Auth
AUTH_SECRET=your-secret-at-least-32-characters-long
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Services
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token
ANTHROPIC_API_KEY=your-anthropic-api-key

# Cron security
CRON_SECRET=your-cron-secret-min-16

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Optional
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_CALCOM_LINK=
# STRIPE_SECRET_KEY=
# RESEND_API_KEY=

# Feature flags
FEATURE_COACHING=false
FEATURE_MARKETPLACE=false
FEATURE_MERCH=false
