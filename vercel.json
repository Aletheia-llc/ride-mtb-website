{
  "regions": ["iad1"],
  "framework": "nextjs",
  "cleanUrls": true,
  "installCommand": "npm ci",
  "buildCommand": "prisma generate && next build",
  "functions": {
    "src/app/api/ai/**": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/xp-streaks",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/notification-digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/feed-scores",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/youtube-rss",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/fantasy/open-rosters",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/fantasy/lock-rosters",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/marketplace-expire",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/events/reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/events/complete-past",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/events/geocode",
      "schedule": "0 2 * * *"
    }
  ]
}
