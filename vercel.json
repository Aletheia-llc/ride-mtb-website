{
  "regions": ["iad1"],
  "framework": "nextjs",
  "cleanUrls": true,
  "installCommand": "npm ci",
  "buildCommand": "prisma generate && next build",
  "functions": {
    "src/app/api/ai/**": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/xp-streaks",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/notification-digest",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/feed-scores",
      "schedule": "0 3 * * 1"
    }
  ]
}
